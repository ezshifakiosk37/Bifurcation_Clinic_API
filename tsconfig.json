{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext", // or "Node"
    "moduleResolution": "NodeNext", // or "Node"
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}